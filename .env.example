# Jarvis configuration — copy to `.env` and edit. All keys are optional;
# omitted keys use the defaults in src/jarvis/config.py. Every variable is
# prefixed JARVIS_. This file is the canonical list of tunables.

# --- Audio I/O ---
JARVIS_SAMPLE_RATE=16000
# JARVIS_INPUT_DEVICE=
# JARVIS_OUTPUT_DEVICE=

# --- Wake word ---
JARVIS_WAKE_WORD=hey_jarvis
# Tuned against the G2.1 soak: 0.9 holds false-accepts within budget against
# near-miss phrases at 100% true-accept. Lower if real-voice wakes feel marginal.
JARVIS_WAKE_THRESHOLD=0.9

# --- Voice activity detection / endpointing ---
JARVIS_VAD_THRESHOLD=0.5
JARVIS_VAD_SILENCE_MS=700

# --- Speech-to-text (whisper.cpp) ---
JARVIS_STT_MODEL=large-v3-turbo
# JARVIS_STT_MODEL_DIR=~/.cache/jarvis/whisper

# --- Text-to-speech (Kokoro, British male voices: bm_george, bm_lewis, bm_fable) ---
JARVIS_TTS_VOICE=bm_george
JARVIS_TTS_SPEED=1.0

# --- Claude Code brain ---
JARVIS_CLAUDE_BINARY=claude
# default | acceptEdits | bypassPermissions | plan
JARVIS_PERMISSION_MODE=acceptEdits

# --- Push-to-talk runtime ---
# Default is Enter-gated push-to-talk. Set JARVIS_PTT_SECONDS for hands-free
# timed turns (records N seconds per turn, no keyboard); JARVIS_MAX_TURNS stops
# the loop after N turns (unset = run until Ctrl-C).
# JARVIS_PTT_SECONDS=8
# JARVIS_MAX_TURNS=5

# --- launchd service (macOS background service: `jarvis service install`) ---
# Reverse-DNS label for the LaunchAgent. Also names the plist
# (~/Library/LaunchAgents/<label>.plist) and the launchctl service target.
JARVIS_SERVICE_LABEL=com.jarvis.voice
# Where the LaunchAgent writes stdout/stderr (created on install).
# JARVIS_SERVICE_LOG_DIR=~/Library/Logs/jarvis

# --- Observability ---
JARVIS_LOG_LEVEL=INFO
